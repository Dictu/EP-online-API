<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" 
           targetNamespace="http://schemas.ep-online.nl/maatwerkadviesbestand" 
           xmlns:tns="http://schemas.ep-online.nl/maatwerkadviesbestand" 
           xmlns:ds="http://www.w3.org/2000/09/xmldsig#" 
           xmlns:xf="http://www.w3.org/2002/06/xmldsig-filter2" 
           xml:lang="nl">
    <xs:import namespace="http://www.w3.org/2000/09/xmldsig#" schemaLocation="xmldsig-core-schema.xsd"/>
    <xs:import namespace="http://www.w3.org/2002/06/xmldsig-filter2" schemaLocation="xmldsig-filter2.xsd"/>
    <xs:import namespace="http://uri.etsi.org/01903/v1.3.2#" schemaLocation="XAdESv132.xsd"/>
    <xs:element name="TailoredAdvice" type="tns:TailoredAdvice"/>
    <xs:complexType name="TailoredAdvice">
        <xs:sequence>
            <xs:element name="TAMeta">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Version" type="tns:Version">
                            <xs:annotation>
                                <xs:documentation>Versiecode van de xml-structuur van het maatwerkadviesbestand.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="Tooling">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="VendorSoftwareKey" type="tns:NameSoftware">
                                        <xs:annotation>
                                            <xs:documentation>Identificatiesleutel van de rekensoftware. Waarde moet overeenkomen met de sleutel van een geregistreerd rekensoftware-pakket.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="VendorSoftwareVersionId" type="tns:VersionSoftware">
                                        <xs:annotation>
                                            <xs:documentation>Identificatie van de versie van de rekensoftware.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element ref="ds:Signature" minOccurs="0" maxOccurs="1"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="TAObject">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="BuildingClass" type="tns:BuildingClass">
                            <xs:annotation>
                                <xs:documentation>Geeft aan of de opname onder woningbouw of utiliteitsbouw valt. De waarde 'residential' wordt gebruikt voor woningbouw, 'commercial' voor utiliteitsbouw.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="ObjectLocationList">
                            <xs:annotation>
                                <xs:documentation>Lijst van locatieidentificaties waarvoor het maatwerkadvies geldt.</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="ObjectLocation" type="tns:ObjectLocationType" maxOccurs="unbounded">
                                        <xs:annotation>
                                            <xs:documentation>Blok met gegevens over de locatie van het pand of adresseerbaar object.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="ValidEPC" type="xs:boolean">
                            <xs:annotation>
                                <xs:documentation>Heeft het object een geregistreerd energielabel binnen het projectbestand. Is niet door iedereen op te geven, daarom optioneel.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="TAAdvice">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="AdviceSources">
                            <xs:annotation>
                                <xs:documentation>Blok met brongegevens van het maatwerkadvies.</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="AdviceDate" type="tns:AdviceDate">
                                        <xs:annotation>
                                            <xs:documentation>Datum waarop de maatwerkadviesparameters zijn opgenomen. Notatie YYYYMMDD. Deze datum moet op of voor de registratiedatum liggen.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="SurveyorIsRegistrationAdvisor" type="xs:boolean">
                                        <xs:annotation>
                                            <xs:documentation>Geeft aan of de opname en registratie van het maatwerkadvies door dezelfde adviseur zijn uitgevoerd. Als false, dan moet Surveyor gevuld worden.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="Surveyor" type="tns:SurveyorType" minOccurs="0"/>
                                    <xs:element name="CalculationType" type="tns:CalculationType">
                                        <xs:annotation>
                                            <xs:documentation>Aanduiding van rekenmethodiek met jaartal.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="BRP" type="xs:boolean">
                                        <xs:annotation>
                                            <xs:documentation>Heeft het maatwerkadvies geleid tot een Renovatiepaspoort?</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                    <xs:element name="UitzonderingGebruikStandaard" type="xs:boolean">
                                        <xs:annotation>
                                            <xs:documentation>Alleen als gevelisolatie technisch of bouwkundig niet mogelijk is, mag de standaard voor vooroorlogse woningen worden gehanteerd. De adviseur legt deze uitzondering vast in de software. Ja/true = uitzondering van toepassing.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="CalculationProfile">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="UsedProfile" type="tns:UsedProfileType">
                                        <xs:annotation>
                                            <xs:documentation>Profiel dat gebruikt wordt voor alle onderdelen. Zodra een onderdeel eigen waarden heeft of een ander profiel, dan is de waarde 'eigen profiel'.</xs:documentation>
                                        </xs:annotation>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="Climate" type="tns:ClimateType"/>
                        <xs:element name="EnergyConsumption">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="Measured" type="tns:MeasuredType"/>
                                    <xs:element name="EnergiegebruikNietPrimairHuidig" type="tns:NietPrimairEnergiegebruikType"/>
                                    <xs:element name="EnergiegebruikNietPrimairAdvice" type="tns:NietPrimairEnergiegebruikType"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="AdviceStepsBRP">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="CurrentSituation" type="tns:BrpStepOptionalHernieuwbaarOpwek"/>
                                    <xs:element name="Step1" type="tns:BrpStepWithInvesteringOptionalHernieuwbaarOpwek"/>
                                    <xs:element name="Step2" type="tns:BrpStepWithInvesteringOptionalHernieuwbaarOpwek"/>
                                    <xs:element name="Step3" type="tns:BrpStepWithInvesteringRequiredHernieuwbaarOpwek"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="Summary">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="CurrentSituation" type="tns:SummaryType"/>
                                    <xs:element name="Advice" type="tns:SummaryType"/>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="SoftwareSpecific" minOccurs="0">
                            <xs:annotation>
                                <xs:documentation>Softwarespecifieke informatie die anders niet in deze XML-structuur past.</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:any namespace="##any" minOccurs="0" maxOccurs="unbounded" processContents="skip"/>
                                </xs:sequence>
                                <xs:attribute name="software" type="xs:string" use="required">
                                    <xs:annotation>
                                        <xs:documentation>Identifier van de software waarvoor dit blok bedoeld is (naam en versie).</xs:documentation>
                                    </xs:annotation>
                                </xs:attribute>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- Version: Versienummer van het maatwerkadviesbestand XML-format. Initiëel is de enige mogelijke waarde 2.00. -->
    <xs:simpleType name="Version">
        <xs:restriction base="xs:string">
            <xs:enumeration value="2.00"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- NameSoftware: Naam van het softwarepakket. -->
    <xs:simpleType name="NameSoftware">
        <xs:restriction base="tns:EpbdNonEmptyString">
            <xs:maxLength value="75"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- VersionSoftware: Versienummer van het softwarepakket. -->
    <xs:simpleType name="VersionSoftware">
        <xs:restriction base="tns:EpbdNonEmptyString">
            <xs:maxLength value="75"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- ObjectLocationType: De objecten waar het advies betrekking op heeft. -->
    <xs:complexType name="ObjectLocationType">
        <xs:sequence>
            <xs:element name="BAGIdentification" type="tns:BAGIdentificationType">
                <xs:annotation>
                    <xs:documentation>Blok met identificatiegegevens van een gebouw volgens BAG.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BuildingAnnotation" type="tns:BuildingIdentification" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Extra identificatie als de combinatie van postcode, huisnummer en -toevoeging niet uniek is.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- BAGIdentificationType: Het BAG identificatie type van het object (BAGResidence, BAGBerth of BAGPitch). -->
    <xs:complexType name="BAGIdentificationType">
        <xs:choice>
            <xs:element name="BAGResidenceId" type="tns:BagId">
                <xs:annotation>
                    <xs:documentation>BAG verblijfsobject-ID.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BAGBerthId" type="tns:BagId">
                <xs:annotation>
                    <xs:documentation>BAG Ligplaats-ID.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BAGPitchId" type="tns:BagId">
                <xs:annotation>
                    <xs:documentation>BAG Standplaats-ID.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:choice>
    </xs:complexType>
    <!-- BagId: Het geldige patroon voor een BAG id. -->
    <xs:simpleType name="BagId">
        <xs:restriction base="xs:long">
            <xs:pattern value="([0-9]{4}(01|02|03)[0-9]{10})"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- BuildingClass: Geeft aan of het gaat om woningbouw of utiliteitsbouw -->
    <xs:simpleType name="BuildingClass">
        <xs:restriction base="xs:string">
            <xs:enumeration value="residential"/>
            <xs:enumeration value="commercial"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- BuildingIdentification: Extra informatie om een gebouw te identificeren waar geen adres voor beschikbaar is.-->
    <xs:simpleType name="BuildingIdentification">
        <xs:restriction base="xs:string">
            <xs:maxLength value="25"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- SurveyDate: Opnamedatum van het maatwerkadvies. -->
    <xs:simpleType name="AdviceDate">
        <xs:restriction base="tns:EpbdDate"/>
    </xs:simpleType>
    <!-- EpbdNonEmptyString: Hulptype voor een string die niet leeg mag zijn. -->
    <xs:simpleType name="EpbdNonEmptyString">
        <xs:restriction base="xs:string">
            <xs:minLength value="1"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- EpbdDate: formaat is YYYYMMDD -->
    <xs:simpleType name="EpbdDate">
        <xs:restriction base="xs:string">
            <xs:length value="8"/>
            <xs:pattern value="([0-9]{4}((0[1-9])|(1[0-2]))((0[1-9])|(([1-2][0-9])|(3[0-1]))))"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- EpbdNumericNoDecimal: Algemeen type voor decimale velden.
            Deze hebben allen een precisie van nul decimalen. -->
    <xs:simpleType name="EpbdNumericNoDecimal">
        <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="0"/>
            <xs:totalDigits value="14"/>
            <xs:minInclusive value="-1"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- EpbdNumeric: Algemeen type voor decimale velden.
            Deze hebben allen een precisie van twee decimalen. -->
    <xs:simpleType name="EpbdNumericTwoDecimal">
        <xs:restriction base="xs:decimal">
            <xs:fractionDigits value="2"/>
            <xs:totalDigits value="14"/>
            <xs:minInclusive value="-1"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="EpbdNumericTwoDecimalWithNegative">
        <xs:restriction base="xs:decimal">
            <xs:pattern value="(-{0,1}[0-9]{1,14}(\.[0-9]{2}){0,1}|-1)" />
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="Maandwaarden">
        <xs:annotation>
            <xs:documentation>Lijst van decimalen, gescheiden door één of meer spaties. De eerste waarde is de jaarwaarde (of 0 als er geen jaarwaarde is), gevolgd door de twaalf maandwaarden.</xs:documentation>
        </xs:annotation>
        <xs:list itemType="xs:double"/>
    </xs:simpleType>
    <!-- SurveyorType: De opnameadviseur.-->
    <xs:complexType name="SurveyorType">
        <xs:sequence>
            <xs:element name="Initials" type="xs:string">
                <xs:annotation>
                    <xs:documentation>Voorletters van de maatwerkadvies-opname-adviseur.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="MiddleName" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Tussenvoegsel van de maatwerkadvies-opname-adviseur.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LastName" type="xs:string">
                <xs:annotation>
                    <xs:documentation>Achternaam van de maatwerkadvies-opname-adviseur.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ProfessionalCompetenceNumber" type="tns:ProfessionalCompetenceNumberType">
                <xs:annotation>
                    <xs:documentation>Vakbekwaamheidsnummer van de maatwerkadvies-opname-adviseur.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- ProfessionalCompetenceNumberType: De restrictie voor het vakbekwaamheidsnummer.-->
    <xs:simpleType name="ProfessionalCompetenceNumberType">
        <xs:restriction base="xs:string">
            <xs:minLength value="3"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- CalculationType: Berekeningswijze.-->
    <xs:simpleType name="CalculationType">
        <xs:restriction base="tns:EpbdNonEmptyString">
            <xs:maxLength value="25"/>
            <xs:enumeration value="NTA_8800_MWA:2025"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- UsedProfileType: Berekeningsprofiel.-->
    <xs:simpleType name="UsedProfileType">
        <xs:restriction base="tns:EpbdNonEmptyString">
            <xs:maxLength value="25"/>
            <xs:enumeration value="Energiebewust"/>
            <xs:enumeration value="Gemiddeld (NTA)"/>
            <xs:enumeration value="Niet energiebewust"/>
            <xs:enumeration value="Eigen profiel"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- ClimateType: De klimaatgegevens.-->
    <xs:complexType name="ClimateType">
        <xs:annotation>
            <xs:documentation>De klimaatgegevens.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Year" type="tns:Year">
                <xs:annotation>
                    <xs:documentation>Het jaar van meetgegevens in het formaat: YYYY.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Month" type="tns:Month">
                <xs:annotation>
                    <xs:documentation>De start maand van meetgegevens in het formaat: MM.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Station" type="tns:ClimateStationType">
                <xs:annotation>
                    <xs:documentation>Het gebruikte klimaatstation.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- Year: formaat is YYYY.-->
    <xs:simpleType name="Year">
        <xs:annotation>
            <xs:documentation>Formaat is YYYY.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="[0-9]{4}"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- Month: formaat is MM.-->
    <xs:simpleType name="Month">
        <xs:annotation>
            <xs:documentation>Formaat is MM.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="0[1-9]|1[0-2]"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- ClimateStationType: De lijst van meetstations.-->
    <xs:simpleType name="ClimateStationType">
        <xs:restriction base="tns:EpbdNonEmptyString">
            <xs:enumeration value="De Bilt (NTA 8800)"/>
            <xs:enumeration value="Arcen"/>
            <xs:enumeration value="Berkhout"/>
            <xs:enumeration value="Cabauw Mast"/>
            <xs:enumeration value="Deelen"/>
            <xs:enumeration value="Eelde"/>
            <xs:enumeration value="Eindhoven"/>
            <xs:enumeration value="Ell"/>
            <xs:enumeration value="Gilze-Rijen"/>
            <xs:enumeration value="Heino"/>
            <xs:enumeration value="Herwijnen"/>
            <xs:enumeration value="Hoek van Holland"/>
            <xs:enumeration value="Hoogeveen"/>
            <xs:enumeration value="Hoorn Terschelling"/>
            <xs:enumeration value="Hupsel"/>
            <xs:enumeration value="De Kooy"/>
            <xs:enumeration value="Lauwersoog"/>
            <xs:enumeration value="Leeuwarden"/>
            <xs:enumeration value="Lelystad"/>
            <xs:enumeration value="Maastricht"/>
            <xs:enumeration value="Marknesse"/>
            <xs:enumeration value="Nieuw Beerta"/>
            <xs:enumeration value="Rotterdam"/>
            <xs:enumeration value="Schiphol"/>
            <xs:enumeration value="Stavoren"/>
            <xs:enumeration value="Twenthe"/>
            <xs:enumeration value="Vlissingen"/>
            <xs:enumeration value="Volkel"/>
            <xs:enumeration value="Voorschoten"/>
            <xs:enumeration value="Westdorpe"/>
        </xs:restriction>
    </xs:simpleType>
    <!-- MeasuredType: De metingen van het verbruik.-->
    <xs:complexType name="MeasuredType">
        <xs:sequence>
            <xs:element name="ValueElectricityTotal" type="tns:EpbdNumericNoDecimal">
                <xs:annotation>
                    <xs:documentation>Het opgegeven jaarverbruik van elektriciteit.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueElectricity" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven maandverbruik van elektriciteit.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueGasTotal" type="tns:EpbdNumericNoDecimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven jaarverbruik van gas.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueGas" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven maandverbruik van gas.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueHeatTotal" type="tns:EpbdNumericNoDecimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven jaarverbruik van warmte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueHeat" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven maandverbruik van warmte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueBiomassTotal" type="tns:EpbdNumericNoDecimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven jaarverbruik van biomassa.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueBiomass" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven maandverbruik van biomassa.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueColdTotal" type="tns:EpbdNumericNoDecimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven jaarverbruik van koude.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueCold" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het opgegeven maandverbruik van koude.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueElectricityProducedTotal" type="tns:EpbdNumericNoDecimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>De opgegeven opwekking totaal van elektriciteit.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValueElectricityProduced" type="tns:Maandwaarden" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>De opgegeven opwekking per maand van elektriciteit.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- NietPrimairEnergiegebruikType: De lijst van niet primair energiegebruiktype.-->
    <xs:complexType name="NietPrimairEnergiegebruikType">
        <xs:annotation>
            <xs:documentation>Jaarlijkse waarden voor het niet‑primaire energiegebruik van het gebouw, opgesplitst naar energiefuncties (optelling van maandelijkse waarden).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Totaal" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het totaal jaarlijkse energiegebruik (niet primair) voor energieprestatie functies.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Verwarming" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het jaarlijkse niet primaire energiegebruik van het gebouw voor verwarming (optelling van maandelijkse waarden).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Koeling" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het jaarlijkse niet primaire energiegebruik van het gebouw voor koeling (optelling van maandelijkse waarden).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Ventilatie" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het jaarlijkse niet primaire energiegebruik van het gebouw voor ventilatie (optelling van maandelijkse waarden).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Verlichting" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het jaarlijkse niet primaire energiegebruik van het gebouw voor verlichting (optelling van maandelijkse waarden).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="WarmTapwater" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
                    <xs:documentation>Het jaarlijkse niet primaire energiegebruik van het gebouw voor warmtapwater (optelling van maandelijkse waarden).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Ontvochtiging" type="tns:EpbdNumericTwoDecimal">
                <xs:annotation>
